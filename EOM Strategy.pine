//@version=6
strategy("OOTM strategy", overlay=true,
     initial_capital=3000,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true,
     max_lines_count=200,
     max_labels_count=200,
     max_boxes_count=50)

// ───────────────────── Inputs (Vienna Time)
string asiaSess   = input.session("0200-0800", "Asia Session (Vienna Time)")
string londonSess = input.session("0900-1200", "London Session (Vienna Time)")
string nySess     = input.session("1530-1900", "New York Session (Vienna Time)")

bool showAsia   = input.bool(true,  "Show Asia H/L")
bool showLondon = input.bool(true,  "Show London H/L")
bool showNY     = input.bool(true,  "Show NY H/L")

int  maLen    = input.int(22, "MA Length")
bool useEMA22 = input.bool(true, "Use EMA22 (else SMA)")
int  trendLen = input.int(200, "Trend EMA Len")

bool showTrades   = input.bool(true, "Show Trade Idea Projection")
bool useRRBox     = input.bool(true, "Use RR Box (cleaner than 3 lines)")
float rr          = input.float(3.0, "RR (TP = RR * Risk)", step=0.1)
int   atrLen      = input.int(14, "ATR Len")
float atrBufMult  = input.float(0.5, "ATR Buffer Mult", step=0.1)
int   projBars    = input.int(150, "Projection bars", minval=50, maxval=500)

bool useTrendFil = input.bool(true, "Trend filter EMA200")
bool useMA22Fil  = input.bool(false, "MA22 filter")
string signalMode = input.string("Sweeps", "Signal Mode", options=["Sweeps", "Breakouts"])
bool tf15mOnly    = input.bool(false, "Only on 15m Timeframe")

bool enableOrders = input.bool(true, "Enable strategy orders (backtest)")
int  maxTradesPerDay = input.int(2, "Max trades per day", minval=0)

bool showStatsTable = input.bool(true, "Show stats table (wins/losses)")

// ───────────────────── RSI Inputs
bool showRsiSignals = input.bool(true, "Show RSI Buy/Sell Signals")
int  rsiLen         = input.int(14, "RSI Length")
string rsiTf        = input.timeframe("15", "RSI Timeframe (Candle Period)")
int  rsiOversold    = input.int(20, "RSI Oversold Level (Buy)")
int  rsiOverbought  = input.int(70, "RSI Overbought Level (Sell)")

// ───────────────────── Helpers
inSession(string sess) =>
    not na(time(timeframe.period, sess, "Europe/Vienna"))

f_num(x) => str.tostring(x, format.mintick)

// ───────────────────── Auto-Detection for GBP / JPY pairs
bool isGBP = str.contains(syminfo.ticker, "GBP")
bool isJPY = str.contains(syminfo.ticker, "JPY")

float baseAtrBufMult = atrBufMult
if isGBP and isJPY
    baseAtrBufMult := atrBufMult * 1.5
else if isGBP
    baseAtrBufMult := atrBufMult * 1.2
else if isJPY
    baseAtrBufMult := atrBufMult * 1.3

// ───────────────────── Trend
float ema22Val = ta.ema(close, maLen)
float sma22Val = ta.sma(close, maLen)
float ma22     = useEMA22 ? ema22Val : sma22Val
float emaTr    = ta.ema(close, trendLen)

plot(ma22,  "MA22", color=color.new(#2196f3, 40))
plot(emaTr, "EMA Trend", color=color.new(#ff5252, 60))

bool trendLongOk  = (not useTrendFil) or close > emaTr
bool trendShortOk = (not useTrendFil) or close < emaTr
bool maLongOk     = (not useMA22Fil) or close > ma22
bool maShortOk    = (not useMA22Fil) or close < ma22

// ───────────────────── RSI MTF Calculation
float rsiValRaw = ta.rsi(close, rsiLen)
float rsiVal = request.security(syminfo.tickerid, rsiTf, rsiValRaw[barstate.isrealtime ? 0 : 1])

bool rsiBuy  = ta.crossunder(rsiVal, rsiOversold)
bool rsiSell = ta.crossover(rsiVal, rsiOverbought)

plotshape(showRsiSignals and rsiBuy,  title="RSI Buy",  style=shape.labelup,   location=location.belowbar, color=color.new(#26a69a, 0), text="RSI BUY",  textcolor=color.white, size=size.small)
plotshape(showRsiSignals and rsiSell, title="RSI Sell", style=shape.labeldown, location=location.abovebar, color=color.new(#ef5350, 0), text="RSI SELL", textcolor=color.white, size=size.small)

// ───────────────────── Session states
bool asia   = inSession(asiaSess)
bool london = inSession(londonSess)
bool ny     = inSession(nySess)

bool asiaStart   = asia and not asia[1]
bool asiaEnd     = (not asia) and asia[1]
bool londonStart = london and not london[1]
bool londonEnd   = (not london) and london[1]
bool nyStart     = ny and not ny[1]
bool nyEnd       = (not ny) and ny[1]

// ───────────────────── Session tracking values
var float aH = na
var float aL = na
var float lH = na
var float lL = na
var float nH = na
var float nL = na

// ───────────────────── Single persistent session lines (NO stacking)
var line aHLine = na
var line aLLine = na
var line lHLine = na
var line lLLine = na
var line nHLine = na
var line nLLine = na

// ───────────────────── Asia session (create once, then update)
if asiaStart
    aH := high
    aL := low
    if showAsia
        line.delete(aHLine)
        line.delete(aLLine)
        aHLine := line.new(bar_index, aH, bar_index + 1, aH, color=color.new(#9c27b0, 20), style=line.style_dashed, width=1, extend=extend.right)
        aLLine := line.new(bar_index, aL, bar_index + 1, aL, color=color.new(#9c27b0, 20), style=line.style_dashed, width=1, extend=extend.right)

if asia
    aH := na(aH) ? high : math.max(aH, high)
    aL := na(aL) ? low  : math.min(aL, low)
    if showAsia and not na(aHLine) and not na(aLLine)
        line.set_y1(aHLine, aH)
        line.set_xy2(aHLine, bar_index + 1, aH)
        line.set_y1(aLLine, aL)
        line.set_xy2(aLLine, bar_index + 1, aL)

if asiaEnd and showAsia and not na(aHLine) and not na(aLLine)
    line.set_y1(aHLine, aH)
    line.set_xy2(aHLine, bar_index + 1, aH)
    line.set_y1(aLLine, aL)
    line.set_xy2(aLLine, bar_index + 1, aL)

// ───────────────────── London session
if londonStart
    lH := high
    lL := low
    if showLondon
        line.delete(lHLine)
        line.delete(lLLine)
        lHLine := line.new(bar_index, lH, bar_index + 1, lH, color=color.new(#00bcd4, 20), style=line.style_dashed, width=1, extend=extend.right)
        lLLine := line.new(bar_index, lL, bar_index + 1, lL, color=color.new(#00bcd4, 20), style=line.style_dashed, width=1, extend=extend.right)

if london
    lH := na(lH) ? high : math.max(lH, high)
    lL := na(lL) ? low  : math.min(lL, low)
    if showLondon and not na(lHLine) and not na(lLLine)
        line.set_y1(lHLine, lH)
        line.set_xy2(lHLine, bar_index + 1, lH)
        line.set_y1(lLLine, lL)
        line.set_xy2(lLLine, bar_index + 1, lL)

if londonEnd and showLondon and not na(lHLine) and not na(lLLine)
    line.set_y1(lHLine, lH)
    line.set_xy2(lHLine, bar_index + 1, lH)
    line.set_y1(lLLine, lL)
    line.set_xy2(lLLine, bar_index + 1, lL)

// ───────────────────── NY session (optional visuals)
if nyStart
    nH := high
    nL := low
    if showNY
        line.delete(nHLine)
        line.delete(nLLine)
        nHLine := line.new(bar_index, nH, bar_index + 1, nH, color=color.new(#ff9800, 20), style=line.style_dashed, width=1, extend=extend.right)
        nLLine := line.new(bar_index, nL, bar_index + 1, nL, color=color.new(#ff9800, 20), style=line.style_dashed, width=1, extend=extend.right)

if ny
    nH := na(nH) ? high : math.max(nH, high)
    nL := na(nL) ? low  : math.min(nL, low)
    if showNY and not na(nHLine) and not na(nLLine)
        line.set_y1(nHLine, nH)
        line.set_xy2(nHLine, bar_index + 1, nH)
        line.set_y1(nLLine, nL)
        line.set_xy2(nLLine, bar_index + 1, nL)

if nyEnd and showNY and not na(nHLine) and not na(nLLine)
    line.set_y1(nHLine, nH)
    line.set_xy2(nHLine, bar_index + 1, nH)
    line.set_y1(nLLine, nL)
    line.set_xy2(nLLine, bar_index + 1, nL)

// ───────────────────── Finalized levels (for sweep logic)
var float aH_final = na
var float aL_final = na
var float lH_final = na
var float lL_final = na

if asiaEnd
    aH_final := aH
    aL_final := aL

if londonEnd
    lH_final := lH
    lL_final := lL

// ───────────────────── Sweep & Breakout logic (IDEA)
bool tfOk = not tf15mOnly or timeframe.period == "15"
bool isSweep = signalMode == "Sweeps"
bool isBreak = signalMode == "Breakouts"

bool asiaReady   = not na(aH_final) and not na(aL_final)
bool londonReady = not na(lH_final) and not na(lL_final)

bool allowAsiaEntries   = (london or ny) and (not asia)
bool allowLondonEntries = ny and (not london)

// Unconditional cross checks (must run on every bar to maintain history)
bool crossAsiaHigh   = ta.crossover(close, aH_final)
bool crossAsiaLow    = ta.crossunder(close, aL_final)
bool crossLondonHigh = ta.crossover(close, lH_final)
bool crossLondonLow  = ta.crossunder(close, lL_final)

// Sweeps (wick breaks, close re-enters)
bool asiaSweepHigh   = isSweep and asiaReady   and allowAsiaEntries   and (high > aH_final) and (close < aH_final) and barstate.isconfirmed
bool asiaSweepLow    = isSweep and asiaReady   and allowAsiaEntries   and (low  < aL_final) and (close > aL_final) and barstate.isconfirmed
bool londonSweepHigh = isSweep and londonReady and allowLondonEntries and (high > lH_final) and (close < lH_final) and barstate.isconfirmed
bool londonSweepLow  = isSweep and londonReady and allowLondonEntries and (low  < lL_final) and (close > lL_final) and barstate.isconfirmed

// Breakouts (close crosses out of session level)
bool asiaBreakHigh   = isBreak and asiaReady   and allowAsiaEntries   and crossAsiaHigh   and barstate.isconfirmed
bool asiaBreakLow    = isBreak and asiaReady   and allowAsiaEntries   and crossAsiaLow    and barstate.isconfirmed
bool londonBreakHigh = isBreak and londonReady and allowLondonEntries and crossLondonHigh and barstate.isconfirmed
bool londonBreakLow  = isBreak and londonReady and allowLondonEntries and crossLondonLow  and barstate.isconfirmed

bool longIdea  = tfOk and ((isSweep and (asiaSweepLow or londonSweepLow)) or (isBreak and (asiaBreakHigh or londonBreakHigh))) and trendLongOk and maLongOk
bool shortIdea = tfOk and ((isSweep and (asiaSweepHigh or londonSweepHigh)) or (isBreak and (asiaBreakLow or londonBreakLow))) and trendShortOk and maShortOk

float refLevelLong = isSweep ? (asiaSweepLow ? aL_final : (londonSweepLow ? lL_final : na)) : (asiaBreakHigh ? aH_final : (londonBreakHigh ? lH_final : na))
float refLevelShort = isSweep ? (asiaSweepHigh ? aH_final : (londonSweepHigh ? lH_final : na)) : (asiaBreakLow ? aL_final : (londonBreakLow ? lL_final : na))

plotshape(longIdea,  title="Long Idea",  style=shape.triangleup,   location=location.belowbar, size=size.tiny, color=color.new(#26a69a, 0), text="L")
plotshape(shortIdea, title="Short Idea", style=shape.triangledown, location=location.abovebar, size=size.tiny, color=color.new(#ef5350, 0), text="S")

// ───────────────────── Projection numbers (RR)
float atr = ta.atr(atrLen)
float buf = atr * baseAtrBufMult
float entry = close

float slLong  = not na(refLevelLong)  ? (refLevelLong - buf) : na
float slShort = not na(refLevelShort) ? (refLevelShort + buf) : na

float tpLong  = not na(slLong)  ? (entry + (entry - slLong) * rr) : na
float tpShort = not na(slShort) ? (entry - (slShort - entry) * rr) : na

// ───────────────────── Trade projection UI
var line  entryLine = na
var line  slLine    = na
var line  tpLine    = na
var label ideaLabel = na
var box   rrBox     = na

// LONG UI
if showTrades and longIdea and not na(slLong) and not na(tpLong)
    line.delete(entryLine)
    line.delete(slLine)
    line.delete(tpLine)
    label.delete(ideaLabel)
    box.delete(rrBox)

    if useRRBox
        float topL = math.max(tpLong, entry)
        float botL = math.min(slLong, entry)
        rrBox := box.new(
            bar_index, topL, bar_index + projBars, botL,
            bgcolor=color.new(#26a69a, 93),
            border_color=color.new(#26a69a, 40),
            border_width=1
        )
    else
        entryLine := line.new(bar_index, entry,   bar_index + projBars, entry,   color=color.new(#787b86, 20),  style=line.style_dotted)
        slLine    := line.new(bar_index, slLong,  bar_index + projBars, slLong,  color=color.new(#ef5350, 20),   style=line.style_dashed)
        tpLine    := line.new(bar_index, tpLong,  bar_index + projBars, tpLong,  color=color.new(#26a69a, 20),   style=line.style_dashed)

    ideaLabel := label.new(
        bar_index + 1, entry,
        "LONG ▶  E:" + f_num(entry) +
        "  SL:" + f_num(slLong) +
        "  TP:" + f_num(tpLong),
        style=label.style_label_left,
        textcolor=color.white,
        color=color.new(#1e222d, 10),
        size=size.small
    )

// SHORT UI
if showTrades and shortIdea and not na(slShort) and not na(tpShort)
    line.delete(entryLine)
    line.delete(slLine)
    line.delete(tpLine)
    label.delete(ideaLabel)
    box.delete(rrBox)

    if useRRBox
        float topS = math.max(slShort, entry)
        float botS = math.min(tpShort, entry)
        rrBox := box.new(
            bar_index, topS, bar_index + projBars, botS,
            bgcolor=color.new(#ef5350, 93),
            border_color=color.new(#ef5350, 40),
            border_width=1
        )
    else
        entryLine := line.new(bar_index, entry,   bar_index + projBars, entry,   color=color.new(#787b86, 20),  style=line.style_dotted)
        slLine    := line.new(bar_index, slShort, bar_index + projBars, slShort, color=color.new(#ef5350, 20),   style=line.style_dashed)
        tpLine    := line.new(bar_index, tpShort, bar_index + projBars, tpShort, color=color.new(#26a69a, 20),   style=line.style_dashed)

    ideaLabel := label.new(
        bar_index + 1, entry,
        "SHORT ▶  E:" + f_num(entry) +
        "  SL:" + f_num(slShort) +
        "  TP:" + f_num(tpShort),
        style=label.style_label_left,
        textcolor=color.white,
        color=color.new(#1e222d, 10),
        size=size.small
    )

// ───────────────────── Trigger logic
bool longOnly  = longIdea and not shortIdea
bool shortOnly = shortIdea and not longIdea

bool longTrig  = longOnly  and not longOnly[1]
bool shortTrig = shortOnly and not shortOnly[1]

// ───────────────────── Max trades per day (Vienna Time)
bool newDay = ta.change(time("D", "", "Europe/Vienna")) != 0

var int tradesToday = 0
if newDay
    tradesToday := 0

bool canTradeToday = tradesToday < maxTradesPerDay
bool flat = strategy.position_size == 0

// ───────────────────── Strategy variables tracking
var float activeSL = na
var float activeTP = na

if flat
    if longTrig and not na(slLong) and not na(tpLong)
        activeSL := slLong
        activeTP := tpLong
        strategy.entry("L", strategy.long)
        tradesToday += 1

    if shortTrig and not na(slShort) and not na(tpShort)
        activeSL := slShort
        activeTP := tpShort
        strategy.entry("S", strategy.short)
        tradesToday += 1

// ───────────────────── Strategy orders
if strategy.position_size > 0
    strategy.exit("L-exit", "L", stop=activeSL, limit=activeTP)
if strategy.position_size < 0
    strategy.exit("S-exit", "S", stop=activeSL, limit=activeTP)

// ───────────────────── WIN/LOSS tracking
var int wins   = 0
var int losses = 0
var int be     = 0

var int winsToday = 0
var int lossesToday = 0
var int beToday = 0

if newDay
    winsToday := 0
    lossesToday := 0
    beToday := 0

var int prevClosedTrades = 0
bool newClosedTrade = strategy.closedtrades > prevClosedTrades

if newClosedTrade
    float lastProfit = strategy.closedtrades.profit(strategy.closedtrades - 1)

    if lastProfit > 0
        wins += 1
        winsToday += 1
    else if lastProfit < 0
        losses += 1
        lossesToday += 1
    else
        be += 1
        beToday += 1

prevClosedTrades := strategy.closedtrades

int totalClosed = wins + losses + be
float winrate = (wins + losses) > 0 ? (wins * 100.0) / (wins + losses) : na

// ───────────────────── Alerts (JSON)
if longTrig and not na(slLong) and not na(tpLong)
    string jLong =
      '{' +
      '"type":"signal",' +
      '"side":"LONG",' +
      '"symbol":"' + syminfo.ticker + '",' +
      '"tf":"' + timeframe.period + '",' +
      '"entry":"' + f_num(entry) + '",' +
      '"sl":"' + f_num(slLong) + '",' +
      '"tp":"' + f_num(tpLong) + '",' +
      '"rr":"' + str.tostring(rr) + '",' +
      '"ts":"' + str.tostring(time) + '"' +
      '}'
    alert(jLong, alert.freq_once_per_bar_close)

if shortTrig and not na(slShort) and not na(tpShort)
    string jShort =
      '{' +
      '"type":"signal",' +
      '"side":"SHORT",' +
      '"symbol":"' + syminfo.ticker + '",' +
      '"tf":"' + timeframe.period + '",' +
      '"entry":"' + f_num(entry) + '",' +
      '"sl":"' + f_num(slShort) + '",' +
      '"tp":"' + f_num(tpShort) + '",' +
      '"rr":"' + str.tostring(rr) + '",' +
      '"ts":"' + str.tostring(time) + '"' +
      '}'
    alert(jShort, alert.freq_once_per_bar_close)

// ───────────────────── Stats table (optional)
if showStatsTable
    var table t = table.new(position.top_right, 2, 8, bgcolor=color.new(#171a24, 5), border_color=color.new(#2a2e39, 10), border_width=1)
    if barstate.islast
        // Styles
        color hdrBg  = #1f222e
        color cellBg = #171a24
        color txtW   = #ffffff
        color txtG   = #d1d4dc
        color greenC = #26a69a
        color redC   = #ef5350
        color grayC  = #787b86
        
        // Header
        table.cell(t, 0, 0, "STATISTIC", bgcolor=hdrBg, text_color=txtW, text_size=size.small, width=12)
        table.cell(t, 1, 0, "VALUE", bgcolor=hdrBg, text_color=txtW, text_size=size.small, width=12)
        
        // Total Closed
        table.cell(t, 0, 1, "Closed Trades", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 1, str.tostring(totalClosed), bgcolor=cellBg, text_color=txtW, text_size=size.small)
        
        // Wins
        table.cell(t, 0, 2, "Wins", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 2, str.tostring(wins), bgcolor=cellBg, text_color=greenC, text_size=size.small)
        
        // Losses
        table.cell(t, 0, 3, "Losses", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 3, str.tostring(losses), bgcolor=cellBg, text_color=redC, text_size=size.small)
        
        // BE
        table.cell(t, 0, 4, "Break Even", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 4, str.tostring(be), bgcolor=cellBg, text_color=grayC, text_size=size.small)
        
        // Winrate
        color wrColor = na(winrate) ? txtW : (winrate >= 50.0 ? greenC : redC)
        string wrStr  = na(winrate) ? "N/A" : str.tostring(winrate, "#.##") + "%"
        table.cell(t, 0, 5, "Winrate", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 5, wrStr, bgcolor=cellBg, text_color=wrColor, text_size=size.small)
        
        // Trades Today
        table.cell(t, 0, 6, "Trades Today", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 6, str.tostring(tradesToday), bgcolor=cellBg, text_color=txtW, text_size=size.small)
        
        // Today Detail
        table.cell(t, 0, 7, "Today (W/L/BE)", bgcolor=cellBg, text_color=txtG, text_size=size.small)
        table.cell(t, 1, 7, str.tostring(winsToday) + " / " + str.tostring(lossesToday) + " / " + str.tostring(beToday), bgcolor=cellBg, text_color=txtW, text_size=size.small)
